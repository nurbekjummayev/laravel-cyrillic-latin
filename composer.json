{
    "name": "nurbekjummayev/laravel-cyrillic-latin",
    "description": "Uzbek Cyrillic <-> Latin transliteration package for Laravel",
    "keywords": ["laravel", "uzbek", "transliteration", "cyrillic", "latin", "translit"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Nurbek Jummayev",
            "email": "jummayevnurbek279@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "NurbekJummayev\\LaravelCyrillicLatin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NurbekJummayev\\LaravelCyrillicLatin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NurbekJummayev\\LaravelCyrillicLatin\\CyrillicLatinServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
